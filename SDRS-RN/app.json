{
  "expo": {
    "name": "SDRS-RN",
    "slug": "SDRS-RN",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "assets": [
      "./assets/data/ship.csv",
      "./assets/data/images.zip",
      "./assets/data/no-image.svg"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "kr.bicheondev.sdrs"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "package": "kr.bicheondev.sdrs"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/MaterialSymbolsRounded.ttf",
            "./assets/fonts/MaterialIconsRound-Regular.otf",
            "./assets/fonts/PretendardGOV-Regular.otf",
            "./assets/fonts/PretendardGOV-Medium.otf",
            "./assets/fonts/PretendardGOV-SemiBold.otf",
            "./assets/fonts/PretendardGOV-Bold.otf"
          ]
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "20d6c246-2051-415d-bcc6-dbdc44ef24bf"
      }
    }
  }
}
